# Django
DJANGO_SECRET_KEY=          # Required in production. Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_DEBUG=True            # Set to False in production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# Database (PostgreSQL in production, SQLite in dev)
# DATABASE_URL=postgres://user:pass@host:5432/flaude

# Redis (required for WebSocket in production)
# REDIS_URL=redis://localhost:6379

# CORS — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,tauri://localhost

# Server base URL (for OAuth redirect)
SERVER_BASE_URL=http://localhost:8888

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord Bot
DISCORD_TOKEN=

# Slack Bot
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
