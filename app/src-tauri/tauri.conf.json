{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flaude",
  "version": "0.2.0",
  "identifier": "com.seunghyunyu.flaude",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flaude",
        "width": 1200,
        "height": 820,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/gws_client_secret.json"],
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Kr-TeamWise/flaude/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBODk1Q0IxOUNENzVENTQKUldSVVhkZWNzVnlKU2svZWxncGc4V1ZWem5QclB1WWNHMzhycXdnUUZQTjYxY0hSbEdhRXlDbjEK"
    }
  }
}
